import shutil

min_version("8.11")

from scripts._helpers import (
    path_provider,
    get_scenarios,
    get_rdir,
    get_shadow,
)
from scripts.helpers import merge_with_defaults, collect_crash_artifacts

# Merge config with defaults to ensure all required keys are present
config = merge_with_defaults(config)

