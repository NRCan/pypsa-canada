# Check if IDEA export is requested
EXPORT_FORMAT = config.get("postprocess", {}).get("export_format", None)

def get_all_targets():
    targets = [
        *rules.solve_planning.output,
        *rules.solve_dispatch.output,
        *rules.post_process_planning.output,
        *rules.post_process_dispatch.output,
        *rules.compare_results.output,
        *rules.copy_config.output,
        *rules.collect_logs.output
    ]

    if EXPORT_FORMAT and EXPORT_FORMAT.lower() == "idea":
        targets.append(*rules.export_idea.output)
    return targets

rule all:
    input:
        get_all_targets()