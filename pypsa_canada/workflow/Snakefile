#cutout_dir = config["atlite"]["cutout_directory"]
#CDIR = Path(cutout_dir).joinpath("" if run["shared_cutouts"] else RDIR)
RESULTS = "results/" + RDIR


# Rules are in order of use
include: "rules/load_network.smk"
include: "rules/add_components.smk"
include: "rules/add_loads.smk"
include: "rules/add_snapshots.smk"
include: "rules/add_representative_days.smk"
include: "rules/add_extra_loads.smk"
include: "rules/modify_components.smk"

include: "rules/solve_planning.smk"

include: "rules/create_dispatch_network.smk"
include: "rules/solve_dispatch.smk"

# Post-processing rules
include: "rules/post_process_planning.smk"
include: "rules/post_process_dispatch.smk"
# include: "rules/plot_corridor_map.smk"
include: "rules/create_summary.smk"
include: "rules/export_idea.smk"

# Check if IDEA export is requested
EXPORT_FORMAT = config.get("postprocess", {}).get("export_format", None)

def get_all_targets():
    targets = [
        f"{RUN_OUTPUT_DIR}/planning_solved_network",
        f"{RUN_OUTPUT_DIR}/dispatch_solved_network",
        f"{RUN_OUTPUT_DIR}/post_process_planning",
        f"{RUN_OUTPUT_DIR}/post_process_dispatch",
        f"{RUN_OUTPUT_DIR}/results_summary.csv",
        # f"{RUN_OUTPUT_DIR}/planning_corridor_utilization_map.html",
        # f"{RUN_OUTPUT_DIR}/dispatch_corridor_utilization_map.html",
        f"{RUN_OUTPUT_DIR}/compare_results",
        f"{RUN_OUTPUT_DIR}/config.yaml",
        f"{RUN_OUTPUT_DIR}/run.log"
    ]
    if EXPORT_FORMAT and EXPORT_FORMAT.lower() == "idea":
        targets.append(f"{RUN_OUTPUT_DIR}/idea_outputs.csv")
    return targets

rule all:
    input:
        get_all_targets()

rule copy_config:
    output:
        f"{RUN_OUTPUT_DIR}/config.yaml"
    run:
        with open(str(output[0]), "w") as f:
            yaml.dump(config, f, default_flow_style=False, allow_unicode=True)

rule collect_logs:
    input:
        rules.load_network.log,
        rules.add_components.log,
        rules.add_loads.log,
        rules.add_snapshots.log,
        rules.add_representative_days.log,
        rules.add_extra_loads.log,
        rules.modify_components.log,
        rules.solve_planning.log,
        rules.create_dispatch_network.log,
        rules.solve_dispatch.log,
        rules.post_process_planning.log,
        rules.post_process_dispatch.log,
        rules.compare_results.log,
    output:
        f"{RUN_OUTPUT_DIR}/run.log"
    shell:
        "cat {input} > {output}"

onerror:
    crash_dir = Path(RUN_RES_DIR) / f"crash_{TIMESTAMP}"
    run_output_dir = Path(RUN_OUTPUT_DIR)
    if run_output_dir.exists():
        run_output_dir.rename(crash_dir)
    print(f"\n--- Crash detected: collecting artifacts to {crash_dir} ---")
    log_files = [
        *rules.load_network.log,
        *rules.add_components.log,
        *rules.add_loads.log,
        *rules.add_snapshots.log,
        *rules.add_representative_days.log,
        *rules.add_extra_loads.log,
        *rules.modify_components.log,
        *rules.solve_planning.log,
        *rules.create_dispatch_network.log,
        *rules.solve_dispatch.log,
        *rules.post_process_planning.log,
        *rules.post_process_dispatch.log,
        *rules.compare_results.log,
    ]
    collect_crash_artifacts(crash_dir, log_files, config, RUN_NET_DIR, RUN_START.timestamp())
    print(f"--- Crash artifacts saved to {crash_dir} ---\n")


rule clean_all:
    message:
        "Cleaning all"
    shell:
        "rm -rf {RCS_DIR}/* {RES_DIR}/* {LOG_DIR}/*"

rule clean_unsolved:
    message:
        "Cleaning run Unsolved"
    shell:
        "rm -rf {NET_DIR}/{RUN_NAME}"

rule clean_results:
    message:
        "Cleaning run Results"
    shell:
        "rm -rf {RES_DIR}/{RUN_NAME}"

rule clean_logs:
    message:
        "Cleaning run Logs"
    shell:
        "rm -rf {LOG_DIR}/{RUN_NAME}"
