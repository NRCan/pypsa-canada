# Check if IDEA export is requested
EXPORT_FORMAT = config.get("postprocess", {}).get("export_format", None)

def get_all_targets():
    targets = [
        f"{RUN_OUTPUT_DIR}/planning_solved_network",
        f"{RUN_OUTPUT_DIR}/dispatch_solved_network",
        f"{RUN_OUTPUT_DIR}/post_process_planning",
        f"{RUN_OUTPUT_DIR}/post_process_dispatch",
        f"{RUN_OUTPUT_DIR}/compare_results",
        f"{RUN_OUTPUT_DIR}/planning_corridor_utilization_map.html",
        f"{RUN_OUTPUT_DIR}/dispatch_corridor_utilization_map.html",
    ]
    if EXPORT_FORMAT and EXPORT_FORMAT.lower() == "idea":
        targets.append(f"{RUN_OUTPUT_DIR}/idea_output")
    return targets

rule all:
    input:
        get_all_targets()

rule clean_all:
    message:
        "Cleaning all"
    shell:
        "rm -rf {RCS_DIR}/* {RES_DIR}/* {LOG_DIR}/*"

rule clean_unsolved:
    message:
        "Cleaning run Unsolved"
    shell:
        "rm -rf {NET_DIR}/{RUN_NAME}"

rule clean_results:
    message:
        "Cleaning run Results"
    shell:
        "rm -rf {RES_DIR}/{RUN_NAME}"

rule clean_logs:
    message:
        "Cleaning run Logs"
    shell:
        "rm -rf {LOG_DIR}/{RUN_NAME}"
